# .env.example
#
# Purpose: This file is for referencing what environment variables are needed in your own .env.local file.
# Last synced: 5-Mar-26

# Google Maps Embed API key (public by necessity — restrict in Google Cloud Console)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# Privy authentication (replaces Supabase Auth)
NEXT_PUBLIC_PRIVY_APP_ID=YOUR_PRIVY_APP_ID_HERE
PRIVY_APP_SECRET=YOUR_PRIVY_APP_SECRET_HERE

# API gateway URL (server-side only — used by API proxy routes)
API_URL=https://api.global.church

OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE

# MCP server URL (server-side only — used by /api/ask route)
MCP_URL=https://api.global.church/v0/mcp

# WARNING: This key is set to rotate every 90 days!
# Server-side only — never expose to browser via NEXT_PUBLIC_ prefix.
GC_API_KEY=YOUR_API_KEY_HERE

# Email provider (Resend) for Request Access submissions
# Generate an API key at https://resend.com/ and add it to your .env.local
RESEND_API_KEY=YOUR_RESEND_API_KEY_HERE
# From address must be a verified identity/domain in your provider
EMAIL_FROM=Trent Sikute <trent@crossexchange.org>
# Override recipient if needed; defaults to trent.sikute@global.church
REQUEST_ACCESS_RECIPIENT=trent.sikute@global.church
FEEDBACK_RECIPIENT=trent.sikute@global.church

# PostHog analytics (public keys — required by client-side SDK)
NEXT_PUBLIC_POSTHOG_HOST=/posthog
NEXT_PUBLIC_POSTHOG_KEY={INSERT_POSTHOG_API_KEY_HERE}

# Supabase (database only — auth is handled by Privy)
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL_HERE
SUPABASE_URL=YOUR_SUPABASE_URL_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# Zuplo Developer API (server-side only) — for programmatic API key management
ZUPLO_DEV_API_KEY=YOUR_ZUPLO_DEV_API_KEY_HERE
ZUPLO_ACCOUNT_NAME=YOUR_ZUPLO_ACCOUNT_NAME_HERE
ZUPLO_BUCKET_NAME=YOUR_ZUPLO_BUCKET_NAME_HERE
